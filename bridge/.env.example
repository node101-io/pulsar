# MongoDB
MONGO_URI=
MONGO_DB=pulsar-bridge

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Mina
MINA_NETWORK=lightnet          # lightnet | devnet | mainnet
MINA_ARCHIVE_ENDPOINT=         # Mina archive node endpoint (API format TBD)
MINA_PRIVATE_KEY=              # Bridge node signing key for Reduce TX
CONTRACT_ADDRESS=              # Mina bridge/settlement contract address

# Pulsar
PULSAR_GRPC_ENDPOINT=localhost:50051   # Validator signature endpoint (gRPC, TBD)

# Bridge config
HARD_FINALITY_BLOCKS=32
POLL_INTERVAL_MS=5000
MAX_RETRY=3

# Optional
NODE_ENV=production
LOG_LEVEL=info
