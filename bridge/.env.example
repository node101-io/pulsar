# MongoDB
MONGO_URI=
MONGO_DB=pulsar-bridge

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Mina
MINA_ARCHIVE_ENDPOINT=   # TODO: archive node endpoint (API format TBD)

# Pulsar
PULSAR_GRPC_ENDPOINT=localhost:50051
PULSAR_PRIVATE_KEY_HEX=

# Bridge Config
HARD_FINALITY_BLOCKS=32
POLL_INTERVAL_MS=5000
MAX_RETRY=3

# Optional
NODE_ENV=production
LOG_LEVEL=info
